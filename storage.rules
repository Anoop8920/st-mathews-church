rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Gallery images - publicly readable, admin writable
    match /gallery/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Downloads - publicly readable, admin writable
    match /downloads/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Family photos - only authenticated users can read
    match /families/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
